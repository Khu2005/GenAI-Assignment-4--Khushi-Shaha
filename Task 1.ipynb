   "source": [
    "sales = [1200,450,980,1500,3000]\n",
    "\n",
    "f=open(\"sales.txt\",\"w\")\n",
    "for i in sales:\n",
    "    f.write(str(i)+'\\n')\n",
    "f.close()"
   ]
