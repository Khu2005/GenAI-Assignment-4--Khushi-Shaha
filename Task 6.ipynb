    "import os\n",
    "path = input(\"Enter the file name:\")\n",
    "\n",
    "if os.path.exists(path):\n",
    "    with open (path) as f:\n",
    "        data = f.read()\n",
    "        print(data)\n",
    "\n",
    "else:\n",
    "    print(\"File does not exist.Please check the file name.\")"
